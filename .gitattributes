# Force LF line endings for shell scripts (cross-platform safety)
bin/opencode-delegate text eol=lf
bin/opencode-jobs text eol=lf

# Markdown and JSON use auto (platform-native on checkout is fine)
*.md text=auto
*.json text=auto
plugins/opencode/bin/opencode-delegate text eol=lf
plugins/opencode/bin/opencode-jobs text eol=lf
