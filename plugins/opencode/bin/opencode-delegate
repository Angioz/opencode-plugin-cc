#!/bin/sh
# opencode-delegate — delegate a task to OpenCode CLI
# Usage: opencode-delegate [--background] "task message"
#
# Auth is managed by OpenCode natively via: opencode providers login
# This script only reads OPENCODE_MODEL from ~/.opencode-plugin/config.sh
#
# Run /opencode:setup first to configure provider + model.

JOBS_DIR="${OPENCODE_JOBS_DIR:-$HOME/.opencode-jobs}"
PLUGIN_CONFIG="$HOME/.opencode-plugin/config.sh"

# Check opencode is installed
if ! command -v opencode > /dev/null 2>&1; then
  echo "ERROR: OpenCode not found in PATH."
  echo "Install: npm install -g opencode-ai"
  echo "Then run /opencode:setup to configure."
  exit 1
fi

# Load model config — try bash config first, then PowerShell config
PS_CONFIG="$HOME/.opencode-plugin/config.ps1"
if [ -f "$PLUGIN_CONFIG" ]; then
  # shellcheck source=/dev/null
  . "$PLUGIN_CONFIG"
elif [ -f "$PS_CONFIG" ]; then
  # Extract OPENCODE_MODEL from PowerShell config (e.g. $env:OPENCODE_MODEL = "value")
  OPENCODE_MODEL=$(grep 'OPENCODE_MODEL' "$PS_CONFIG" | sed "s/.*= *['\"]//;s/['\"].*//")
  export OPENCODE_MODEL
fi

# Build model flag
MODEL_FLAG=""
if [ -n "$OPENCODE_MODEL" ]; then
  MODEL_FLAG="-m $OPENCODE_MODEL"
else
  echo "WARNING: No model configured. Run /opencode:setup to pick one."
  echo "Proceeding with OpenCode's default model."
fi

# Parse --background flag
BACKGROUND=0
if [ "$1" = "--background" ]; then
  BACKGROUND=1
  shift
fi

MESSAGE="$*"

if [ -z "$MESSAGE" ]; then
  echo "Usage: opencode-delegate [--background] \"task message\""
  echo "  Sync:       opencode-delegate \"summarize src/components\""
  echo "  Background: opencode-delegate --background \"find all TODOs\""
  exit 1
fi

# ── SYNC MODE ────────────────────────────────────────────────────────────────
if [ "$BACKGROUND" = "0" ]; then
  # shellcheck disable=SC2086
  opencode run $MODEL_FLAG "$MESSAGE"
  exit $?
fi

# ── BACKGROUND MODE ──────────────────────────────────────────────────────────
mkdir -p "$JOBS_DIR"

JOB_ID="$(date +%s)-$$"
LOG_FILE="$JOBS_DIR/$JOB_ID.log"
META_FILE="$JOBS_DIR/$JOB_ID.json"
STARTED_AT="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"

cat > "$META_FILE" <<METADATA
{
  "id": "$JOB_ID",
  "status": "running",
  "message": $(printf '%s' "$MESSAGE" | awk 'BEGIN{ORS=""} {gsub(/"/,"\\\""); print "\""$0"\""}'),
  "started_at": "$STARTED_AT",
  "pid": null
}
METADATA

# shellcheck disable=SC2086
opencode run $MODEL_FLAG "$MESSAGE" > "$LOG_FILE" 2>&1 &
JOB_PID=$!

cat > "$META_FILE" <<METADATA
{
  "id": "$JOB_ID",
  "status": "running",
  "message": $(printf '%s' "$MESSAGE" | awk 'BEGIN{ORS=""} {gsub(/"/,"\\\""); print "\""$0"\""}'),
  "started_at": "$STARTED_AT",
  "pid": $JOB_PID
}
METADATA

echo "Job started: $JOB_ID"
echo "Check:   opencode-jobs status $JOB_ID"
echo "Result:  opencode-jobs result $JOB_ID"
echo "Cancel:  opencode-jobs cancel $JOB_ID"
